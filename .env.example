# =============================================================================
# BATS IoT — Variables de entorno v1.0
# =============================================================================
# Copia este fichero: cp .env.example .env
# NUNCA subas el .env real a Git (está en .gitignore).
#
# Para generar claves seguras:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# --- BASE DE DATOS ---
MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_DATABASE=control_asistencia
MYSQL_USER=bats_app
MYSQL_PASSWORD=cambia_esto_app

# --- FLASK ---
FLASK_SECRET_KEY=cambia_esto_con_una_clave_larga_y_aleatoria
# Clave que el contenedor scheduler usa para autenticarse en Flask vía
# la cabecera X-Scheduler-Key. Sin ella, las llamadas automáticas a
# /escanear e /informes/generar-cron serán rechazadas.
SCHEDULER_KEY=cambia_esto_con_otra_clave_aleatoria
# Por defecto 'false': el acceso por IP local (HTTP) funciona siempre.
# Cloudflare ya fuerza HTTPS en el navegador, así que la protección real
# viene del túnel, no del flag Secure en la cookie.
# Cambia a 'true' solo si despliegas Flask con HTTPS directo sin Cloudflare.
SESSION_COOKIE_SECURE=false

# --- TELEGRAM ---
# Token del bot obtenido desde @BotFather
TELEGRAM_TOKEN=
# ID del chat donde se enviarán las alertas
# Puedes obtenerlo en: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# --- CLOUDFLARE TUNNEL ---
# Token del túnel obtenido en:
#   one.dash.cloudflare.com → Networks → Tunnels → (tu túnel) → Configure
# El token es una cadena larga que empieza por "eyJ..."
CLOUDFLARE_TUNNEL_TOKEN=pega_aqui_el_token_del_tunel

# --- CORREO (Gmail con contraseña de aplicación) ---
# Servidor SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Cuenta Gmail desde la que se envían los correos
EMAIL_USER=tu_cuenta@gmail.com
# Contraseña de aplicación (NO la contraseña normal de Gmail)
# Obtenerla en: Cuenta Google → Seguridad → Contraseñas de aplicación
EMAIL_PASSWORD=
# Nombre visible en el campo "De:" del correo (opcional, por defecto usa EMAIL_USER)
EMAIL_FROM=BATS <tu_cuenta@gmail.com>

# --- CONFIGURACIÓN GENERAL ---
# Nombre del centro educativo (aparece en los correos enviados)
NOMBRE_CENTRO=Mi Centro Educativo
# Zona horaria
TZ=Europe/Madrid
